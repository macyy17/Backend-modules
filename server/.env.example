# Optional: skip interactive module picker
# MODULE=translator

# Runner HTTP port
PORT=3333

# PostgreSQL connection string passed to modules through context.databaseUrl
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/module_runner

# Translator module Groq key. Keep the real value in server/.env or root .env, not in git.
GROQ_API_KEY=
