{
  "name": "module-runner-server",
  "version": "0.2.0",
  "private": true,
  "description": "Interactive TypeScript runner for testing portable backend modules.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "check": "tsc --noEmit",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx src/db/runModuleDatabaseFiles.ts migrate",
    "db:seed": "tsx src/db/runModuleDatabaseFiles.ts seed",
    "db:reset": "tsx src/db/runModuleDatabaseFiles.ts reset"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
